			.mapplic-tooltip p {
   color: #999;
   font-size: 12px;
	line-height: 16px;
}

.mapplic-element {
    background-color: #ffffff;
}

.mapplic-list-container {box-shadow: none !important;}

.mapplic-sidebar-nosearch {padding-top: 0 !important;}

.shfb-header.shfb-desktop {
	background-color: #ffffff !important;
}

.shfb-row-wrapper .shfb-main_header_row .shfb-sticky-header {
		background-color: #ffffff !important;
}

.sticky-header-active .shfb.shfb-header.has-sticky-header.sticky-row-main-header-row .sticky-active {
	background-color: #ffffff !important;
}

.entry-footer {
	margin-top:0px;
}

.shfb-footer .shfb-component-widget2 .widget-column .widget a {
	color: #fff !important;
}

.shfb-row-wrapper .shfb-main_header_row .shfb-sticky-header .sticky-active {
	background-color: #ffffff !important;
}

.shfb-row-wrapper .shfb-above_footer_row {
	background-color:#00C4DA !important;
}

.shfb.shfb-mobile_offcanvas #mainnav a.sydney-dropdown-link {
	color: #dedede !important;
}

/* CONTENEDOR */
.wp-block-social-links {
    gap: 14px;
    justify-content: center;
}

/* CADA ICONO */
.wp-social-link a {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    
    display: flex;
    align-items: center;
    justify-content: center;

    transition: all 0.3s ease;
}

/* ICONOS SVG */
.wp-social-link svg {
    width: 22px;
    height: 22px;
    fill: white;
}

/* INSTAGRAM */
.wp-social-link-instagram a {
    background: #666666;
}

/* X / TWITTER */
.wp-social-link-twitter a,
.wp-social-link-x a {
    background: #666666;
}

/* FACEBOOK */
.wp-social-link-facebook a {
    background: #666666;
}

/* LINKEDIN */
.wp-social-link-linkedin a {
    background: #666666;
}

/* HOVER */
.wp-social-link a:hover {
    transform: translateY(-3px);
    opacity: 0.9;
}

/* SACAR LOS PUNTOS NEGROS */
.wp-block-social-links li {
    list-style: none !important;
}

.wp-block-social-links {
    padding-left: 0;
    margin-left: 0;
}

.shfb-footer .shfb-component-widget2 .widget-column .widget a, li {
	color: #666666 !important;
	font-weight: 500;
}		</style>
